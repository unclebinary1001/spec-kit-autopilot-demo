{
  "name": "todo-list-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "next dev src/frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "next build src/frontend",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "better-sqlite3": "^9.4.3",
    "concurrently": "^8.2.2",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.4",
    "next": "^14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.3.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
